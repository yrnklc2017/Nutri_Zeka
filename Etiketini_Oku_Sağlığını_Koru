// MATCH
const MATCH_SETS=[
  {pairs:[["E300","C Vitamini"],["E621","MSG / Tat Artırıcı"],["E471","Emülgatör"],["E951","Aspartam"],["E440","Pektin"]]},
  {pairs:[["Şeker < 5g","🟢 Az"],["Şeker > 12g","🔴 Fazla"],["Tuz > 1.5g","🔴 Fazla"],["Lif > 3g","🟢 İyi"],["Protein > 5g","🟢 İyi"]]},
  {pairs:[["Hidrojene yağ","Trans yağ ❌"],["Omega-3","Sağlıklı yağ ✅"],["Fruktoz","Gizli şeker ⚠️"],["Pektin","Doğal katkı ✅"],["Tartrazin","Yapay boya ⚠️"]]},
];
let matchState={};
function startMatch(){
  const set=MATCH_SETS[Math.floor(Math.random()*MATCH_SETS.length)];
  const rights=[...set.pairs.map(p=>p[1])].sort(()=>Math.random()-.5);
  matchState={pairs:set.pairs,sel:null,matched:new Set(),score:0,lefts:set.pairs.map(p=>p[0]),rights,total:set.pairs.length};
  renderMatch();
}
function renderMatch(){
  const s=matchState;
  document.getElementById("quizArea").innerHTML=`<div class="q-meta">Eşleştirme — ${s.matched.size/2|0}/${s.total} eşleşti</div><div class="q-txt">Sol ve sağdaki kartları eşleştir!</div><div class="match-grid"><div class="match-col" id="mLeft">${s.lefts.map((l,i)=>`<div class="match-item${s.matched.has("L"+i)?" matched":""}" id="mL${i}" onclick="matchClick('L',${i})">${l}</div>`).join("")}</div><div class="match-col" id="mRight">${s.rights.map((r,i)=>`<div class="match-item${s.matched.has("R"+i)?" matched":""}" id="mR${i}" onclick="matchClick('R',${i})">${r}</div>`).join("")}</div></div><div id="matchFb" style="display:none" class="q-fb on"></div>`;
}
function matchClick(side,idx){
  const s=matchState;if(s.matched.has(side+idx))return;
  const el=document.getElementById("m"+side+idx);
  if(!s.sel){s.sel={side,idx};el.classList.add("selected");}
  else{
    if(s.sel.side===side){document.querySelectorAll(".match-item").forEach(e=>e.classList.remove("selected"));s.sel={side,idx};el.classList.add("selected");return;}
    const lIdx=side==="L"?idx:s.sel.idx,rIdx=side==="R"?idx:s.sel.idx;
    const ok=s.pairs.some(p=>p[0]===s.lefts[lIdx]&&p[1]===s.rights[rIdx]);
    if(ok){
      s.matched.add("L"+lIdx);s.matched.add("R"+rIdx);s.score++;
      document.getElementById("mL"+lIdx).className="match-item matched";document.getElementById("mR"+rIdx).className="match-item matched";
      const fb=document.getElementById("matchFb");fb.style.cssText="display:block;background:var(--green-bg);border-color:var(--green-border);color:var(--green-text)";fb.textContent="✅ Doğru!";
      if(s.score>=s.total)setTimeout(()=>showResult(s.score,s.total,"match"),700);
    } else {
      el.classList.add("wrong-flash");document.getElementById("m"+s.sel.side+s.sel.idx).classList.add("wrong-flash");
      const fb=document.getElementById("matchFb");fb.style.cssText="display:block;background:var(--red-bg);border-color:var(--red-border);color:var(--red-text)";fb.textContent="❌ Yanlış, tekrar dene!";
      setTimeout(()=>{el.classList.remove("wrong-flash","selected");document.getElementById("m"+s.sel.side+s.sel.idx).classList.remove("wrong-flash","selected");},700);
    }
    s.sel=null;
  }
}

// FILL
const FILL_QS=[
  {before:"100g başına şeker",blank:"___",after:"gramdan az ise yeşil renk alır.",answer:"5",options:["5","12","25","3"]},
  {before:"İçerik listesi",blank:"___",after:"doğru sıralanır.",answer:"en çoktan en aza",options:["en çoktan en aza","alfabetik","rastgele","en azdan en çoğa"]},
  {before:"Doymuş yağın 'az' sınırı 100g başına",blank:"___",after:"gramdır.",answer:"1.5",options:["1.5","5","3","10"]},
  {before:"E300 kodu",blank:"___",after:"vitaminine karşılık gelir.",answer:"C",options:["C","D","B12","A"]},
  {before:"Trans yağ etikette '",blank:"___",after:"bitkisel yağ' olarak geçer.",answer:"hidrojene",options:["hidrojene","doğal","rafine","sızma"]},
];
let fillIdx=0,fillScore=0;
function startFill(){fillIdx=0;fillScore=0;renderFill();}
function renderFill(){
  const q=FILL_QS[fillIdx];const opts=[...q.options].sort(()=>Math.random()-.5);
  document.getElementById("quizArea").innerHTML=`<div class="q-prog-wrap"><div class="q-prog" style="width:${(fillIdx/FILL_QS.length)*100}%"></div></div><div class="q-meta">Boşluk Doldur — ${fillIdx+1}/${FILL_QS.length}</div><div class="q-txt">Uygun kelimeyi seçerek cümleyi tamamla:</div><div class="fill-sentence" id="fillS">${q.before} <span class="fill-blank" id="fillB">___</span> ${q.after}</div><div class="fill-options">${opts.map(o=>`<div class="fill-chip" id="fco_${o.replace(/ /g,'_')}" onclick="fillSelect('${o.replace(/ /g,'_')}')">${o}</div>`).join("")}</div><div class="q-fb" id="fillFb" style="display:none"></div><button class="q-next" id="fillNext" style="display:none" onclick="nextFill()">Sonraki →</button>`;
}
function fillSelect(raw){
  const o=raw.replace(/_/g,' ');if(document.getElementById("fillNext").style.display!=="none")return;
  const q=FILL_QS[fillIdx];const ok=o===q.answer;if(ok)fillScore++;
  const b=document.getElementById("fillB");b.textContent=o;b.classList.add(ok?"filled":"wrong");
  document.querySelectorAll(".fill-chip").forEach(c=>{c.style.pointerEvents="none";if(c.textContent===q.answer)c.style.cssText="background:var(--green-bg);border-color:var(--green);color:var(--green-text)";});
  const fb=document.getElementById("fillFb");fb.textContent=ok?`✅ Doğru!`:`❌ Yanlış! Doğru: "${q.answer}"`;fb.style.cssText=`display:block;background:${ok?"var(--green-bg)":"var(--red-bg)"};border-color:${ok?"var(--green-border)":"var(--red-border)"};color:${ok?"var(--green-text)":"var(--red-text)"}`;
  const nb=document.getElementById("fillNext");nb.style.display="block";nb.textContent=fillIdx<FILL_QS.length-1?"Sonraki →":"Sonuçları gör →";
}
function nextFill(){fillIdx++;if(fillIdx>=FILL_QS.length)showResult(fillScore,FILL_QS.length,"fill");else renderFill();}

// SORT
const SORT_SETS=[
  {title:"Şeker miktarını küçükten büyüğe sırala:",items:["Meyve suyu ~9g","Elma ~10g","Bisküvi ~30g","Çikolata ~55g"],correct:[0,1,2,3]},
  {title:"Tuz miktarını az'dan çok'a sırala:",items:["Domates ~0.01g","Tam ekmek ~0.9g","Peynir ~1.2g","Cips ~1.8g"],correct:[0,1,2,3]},
  {title:"Lif miktarını az'dan çok'a sırala:",items:["Beyaz pirinç 0.4g","Elma 2.4g","Mercimek 8g","Yulaf 10g"],correct:[0,1,2,3]},
];
let sortState={};
function startSort(){
  const set=SORT_SETS[Math.floor(Math.random()*SORT_SETS.length)];
  sortState={set,items:[...set.items].sort(()=>Math.random()-.5),dragging:null};renderSort();
}
function renderSort(){
  const s=sortState;
  document.getElementById("quizArea").innerHTML=`<div class="q-meta">Sıralama</div><div class="q-txt">${s.set.title}</div><div class="sort-list" id="sortList">${s.items.map((item,i)=>`<div class="sort-item" id="si${i}" draggable="true" ondragstart="sortState.dragging=${i}" ondragover="event.preventDefault()" ondrop="dropSort(${i})"><span class="sort-handle">☰</span><span>${item}</span></div>`).join("")}</div><div class="q-fb" id="sortFb" style="display:none"></div><button class="q-next on" style="display:block" onclick="checkSort()">Kontrol et ✓</button>`;
}
function dropSort(i){
  const s=sortState;if(s.dragging===null||s.dragging===i)return;
  const arr=s.items;const tmp=arr[s.dragging];arr[s.dragging]=arr[i];arr[i]=tmp;s.dragging=null;renderSort();
}
function checkSort(){
  const s=sortState;
  const curOrder=s.items.map(item=>s.set.items.indexOf(item));
  const isOk=JSON.stringify(curOrder)===JSON.stringify(s.set.correct);
  const fb=document.getElementById("sortFb");
  if(isOk){
    document.querySelectorAll(".sort-item").forEach(el=>el.classList.add("correct-pos"));
    fb.style.cssText="display:block;background:var(--green-bg);border-color:var(--green-border);color:var(--green-text)";fb.textContent="🎉 Mükemmel sıralama!";
    setTimeout(()=>showResult(1,1,"sort"),1000);
  } else {
    document.querySelectorAll(".sort-item").forEach(el=>el.classList.add("wrong-pos"));
    fb.style.cssText="display:block;background:var(--red-bg);border-color:var(--red-border);color:var(--red-text)";fb.textContent="❌ Yanlış sıralama, tekrar dene!";
    setTimeout(()=>{document.querySelectorAll(".sort-item").forEach(el=>el.classList.remove("wrong-pos"));fb.style.display="none";},1200);
  }
}

function showResult(score,total,type){
  const pct=Math.round((score/total)*100);
  const e=pct>=90?"🏆":pct>=70?"🎉":pct>=50?"👏":"💪";
  const tt=pct>=90?"Mükemmel!":pct>=70?"Harika!":pct>=50?"İyi iş!":"Devam et!";
  if(score>qb){qb=score;save();}
  const xpMap={mcq:score*5,match:score*8,fill:score*6,sort:10};
  const earned=xpMap[type]||score*5;addXP(earned,`Test bitti! +${earned} XP 🧠`);
  let bh="";BADGES.forEach(b=>{if(b.c())bh+=`<div class="bp" style="background:var(--green-bg);border-color:var(--green-border);color:var(--green-text)">${b.ico} ${b.nm}</div>`;});
  document.getElementById("quizArea").innerHTML=`<div class="qr-wrap"><div class="qr-ico">${e}</div><div class="qr-title">${tt}</div><div class="qr-score">${score}/${total}</div><div class="qr-sub">${pct>=70?"Harika iş çıkardın!":"Öğren sekmesini tekrar incele!"}</div><div class="badges-row">${bh}</div><button class="retry-btn" onclick="renderQuizHome(${currentQuizType})">🔄 Tekrar dene</button></div>`;
}

load();upProf();renderQuizHome(0);
</script>
