<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>NutriZeka</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{
  --green:#16a34a;--green-bg:#f0fdf4;--green-border:#bbf7d0;--green-text:#15803d;
  --yellow:#d97706;--yellow-bg:#fffbeb;--yellow-border:#fde68a;--yellow-text:#b45309;
  --red:#dc2626;--red-bg:#fef2f2;--red-border:#fecaca;--red-text:#b91c1c;
  --blue:#2563eb;--blue-bg:#eff6ff;--blue-border:#bfdbfe;--blue-text:#1d4ed8;
  --purple:#7c3aed;--purple-bg:#f5f3ff;--purple-border:#ddd6fe;--purple-text:#6d28d9;
  --bg:#f8f9fa;--border:#e5e7eb;--text:#111827;--muted:#6b7280;
  --radius:16px;--radius-sm:10px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);max-width:430px;margin:0 auto;min-height:100vh;}
.scr{display:none;padding:0 0 84px;}
.scr.on{display:block;}
.bnav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:#fff;border-top:1px solid var(--border);display:flex;z-index:99;padding-bottom:env(safe-area-inset-bottom,0);}
.nb{flex:1;padding:10px 2px 8px;border:none;background:transparent;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:3px;font-size:9px;font-family:'Nunito',sans-serif;color:var(--muted);font-weight:700;}
.nb.on{color:var(--green);}
.nb svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
.hdr{background:#fff;border-bottom:1px solid var(--border);padding:14px 16px 12px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.hdr-name{font-size:18px;font-weight:900;color:var(--text);}
.hdr-name span{color:var(--green);}
.xpb{background:var(--green-bg);border:1px solid var(--green-border);border-radius:20px;padding:5px 12px;font-size:12px;font-weight:700;color:var(--green-text);}
.pad{padding:16px;}
/* SCAN */
.upload-area{border:2px dashed var(--border);border-radius:var(--radius);padding:28px 20px;text-align:center;cursor:pointer;background:#fff;transition:all .2s;margin-bottom:12px;position:relative;}
.upload-area:hover,.upload-area:focus-within{border-color:var(--green);background:var(--green-bg);}
.upload-area input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.cam-area{border:2px dashed var(--border);border-radius:var(--radius);padding:18px;text-align:center;cursor:pointer;background:#fff;margin-bottom:14px;position:relative;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:10px;font-size:15px;font-weight:800;}
.cam-area:hover{border-color:var(--green);background:var(--green-bg);}
.cam-area input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.or-div{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
.or-div::before,.or-div::after{content:'';flex:1;height:1px;background:var(--border);}
.or-div span{font-size:12px;color:var(--muted);font-weight:700;}
.tips-box{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;}
.tips-lbl{font-size:11px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
.tip-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;font-size:13px;color:var(--muted);font-weight:600;}
.tip-row:last-child{margin-bottom:0;}
.t-dot{width:6px;height:6px;border-radius:50%;background:var(--green);flex-shrink:0;}
.prev-box{border-radius:var(--radius);overflow:hidden;position:relative;border:1px solid var(--border);margin-bottom:14px;}
.prev-box img{width:100%;display:block;max-height:260px;object-fit:cover;}
.ld-over{position:absolute;inset:0;background:rgba(0,0,0,.55);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;}
.ld-txt{font-size:13px;color:#6ee7b7;font-weight:700;font-family:monospace;}
.ld-bar{width:70%;height:4px;background:rgba(255,255,255,.15);border-radius:4px;overflow:hidden;}
.ld-fill{height:100%;background:#16a34a;border-radius:4px;animation:lfill 2s ease-in-out infinite alternate;}
@keyframes lfill{from{width:8%}to{width:95%}}
.err-box{background:var(--red-bg);border:1px solid var(--red-border);border-radius:var(--radius);padding:20px;text-align:center;margin-bottom:12px;}
.err-msg{font-size:13px;color:var(--red-text);margin-bottom:14px;line-height:1.5;font-weight:600;}
.err-btn{padding:10px 22px;background:#fff;border:1px solid var(--red-border);border-radius:var(--radius-sm);color:var(--red-text);font-size:13px;font-weight:800;cursor:pointer;font-family:'Nunito',sans-serif;}
.score-card{background:#fff;border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;margin-bottom:12px;position:relative;overflow:hidden;}
.score-stripe{position:absolute;top:0;left:0;right:0;height:4px;}
.ring-wrap{position:relative;width:110px;height:110px;margin:0 auto 12px;}
.ring-wrap svg{transform:rotate(-90deg);}
.ring-ctr{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.ring-num{font-size:30px;font-weight:900;line-height:1;}
.ring-max{font-size:11px;color:var(--muted);font-weight:700;}
.sc-badge{display:inline-block;padding:5px 16px;border-radius:20px;font-size:13px;font-weight:800;margin-bottom:8px;}
.sc-name{font-size:16px;font-weight:800;margin-bottom:3px;}
.sc-sub{font-size:12px;color:var(--muted);font-weight:600;}
.sec-lbl{font-size:11px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin:0 16px 8px;}
.nut-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:0 16px 12px;}
.nut-c{background:#fff;border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px;border-bottom-width:3px;}
.nt-i{font-size:20px;margin-bottom:4px;}
.nt-l{font-size:10px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px;}
.nt-v{font-size:17px;font-weight:900;margin-bottom:5px;}
.nt-v small{font-size:11px;font-weight:600;color:var(--muted);}
.nt-b{font-size:10px;font-weight:800;padding:3px 8px;border-radius:20px;display:inline-block;}
.warn-wrap{margin:0 16px 12px;}
.warn-item{display:flex;align-items:flex-start;gap:10px;padding:11px 13px;border-radius:var(--radius-sm);margin-bottom:8px;font-size:13px;line-height:1.5;font-weight:600;border-width:1px;border-style:solid;}
.adds-wrap{display:flex;flex-wrap:wrap;gap:6px;margin:0 16px 12px;}
.add-chip{font-size:11px;font-weight:800;padding:5px 11px;border-radius:20px;border-width:1px;border-style:solid;}
.adv-box{margin:0 16px 12px;background:var(--blue-bg);border:1px solid var(--blue-border);border-radius:var(--radius-sm);padding:14px;}
.adv-lbl{font-size:11px;font-weight:800;color:var(--blue-text);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;}
.adv-txt{font-size:13px;line-height:1.6;font-weight:600;}
.action-row{display:flex;gap:8px;margin:0 16px 14px;}
.btn-out{flex:1;padding:12px;background:#fff;border:2px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-weight:800;color:var(--text);cursor:pointer;font-family:'Nunito',sans-serif;display:flex;align-items:center;justify-content:center;gap:6px;}
.btn-green{border-color:var(--green);color:var(--green);}
/* ARCHIVE */
.arc-empty{text-align:center;padding:40px 20px;color:var(--muted);}
.arc-item{background:#fff;border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin-bottom:10px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:background .15s;}
.arc-item:hover{background:var(--green-bg);}
.arc-thumb{width:52px;height:52px;border-radius:var(--radius-sm);object-fit:cover;flex-shrink:0;border:1px solid var(--border);}
.arc-thumb-ph{width:52px;height:52px;border-radius:var(--radius-sm);background:var(--bg);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.arc-info{flex:1;min-width:0;}
.arc-name{font-size:14px;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.arc-meta{font-size:11px;color:var(--muted);font-weight:600;margin-top:2px;}
.arc-score-num{font-size:20px;font-weight:900;}
.arc-score-lbl{font-size:10px;font-weight:700;color:var(--muted);}
.arc-del{flex-shrink:0;padding:6px 8px;background:none;border:none;cursor:pointer;color:var(--muted);font-size:18px;}
/* COMPARE */
.cmp-sel{background:#fff;border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 14px;margin-bottom:10px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;transition:background .15s;}
.cmp-sel:hover{background:var(--green-bg);}
.cmp-sel.picked{border-color:var(--green);background:var(--green-bg);}
.cmp-sel-name{font-size:13px;font-weight:800;}
.cmp-sel-meta{font-size:11px;color:var(--muted);font-weight:600;}
.cmp-check{color:var(--green);font-size:18px;display:none;}
.cmp-sel.picked .cmp-check{display:block;}
.cmp-btn{width:100%;padding:14px;background:var(--green);border:none;border-radius:var(--radius-sm);font-size:14px;font-weight:800;color:#fff;cursor:pointer;font-family:'Nunito',sans-serif;margin-top:4px;}
.cmp-btn:disabled{background:#d1d5db;cursor:not-allowed;}
.cmp-table{background:#fff;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:12px;}
.cmp-hdr-row{display:grid;grid-template-columns:1fr 1fr 1fr;background:var(--bg);border-bottom:1px solid var(--border);}
.cmp-hdr-cell{padding:10px 8px;font-size:11px;font-weight:800;color:var(--muted);text-transform:uppercase;text-align:center;}
.cmp-hdr-cell:first-child{text-align:left;}
.cmp-row{display:grid;grid-template-columns:1fr 1fr 1fr;border-bottom:1px solid var(--bg);padding:10px 8px;align-items:center;}
.cmp-row:last-child{border-bottom:none;}
.cmp-cell{font-size:13px;font-weight:700;text-align:center;}
.cmp-cell:first-child{font-size:12px;font-weight:800;color:var(--muted);text-align:left;}
.cmp-winner{font-weight:900;color:var(--green-text);}
.cmp-loser{color:var(--red-text);}
/* LEARN */
.learn-cat{background:linear-gradient(135deg,var(--green-bg),var(--blue-bg));border:1px solid var(--green-border);border-radius:var(--radius);padding:14px 16px;margin-bottom:10px;cursor:pointer;display:flex;align-items:center;gap:12px;transition:transform .15s;}
.learn-cat:hover{transform:scale(1.01);}
.lc-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.lc-title{font-size:15px;font-weight:800;margin-bottom:2px;}
.lc-sub{font-size:12px;color:var(--muted);font-weight:600;}
.lc-prog{font-size:11px;font-weight:700;margin-top:4px;}
.lesson-row{background:#fff;border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin-bottom:8px;cursor:pointer;display:flex;align-items:center;gap:12px;transition:background .15s;}
.lesson-row:hover{background:var(--green-bg);}
.lr-ico{width:40px;height:40px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.lr-done{margin-left:auto;font-size:16px;color:var(--green);display:none;flex-shrink:0;}
.ld-back{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:800;color:var(--green);cursor:pointer;margin-bottom:16px;}
.info-blk{background:#fff;border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin-bottom:10px;}
.info-blk h3{font-size:14px;font-weight:800;margin-bottom:6px;}
.info-blk p{font-size:13px;color:var(--muted);line-height:1.6;font-weight:600;}
.color-row{display:flex;gap:8px;margin-top:10px;}
.cb{flex:1;padding:8px 4px;border-radius:var(--radius-sm);text-align:center;font-size:12px;font-weight:800;border-width:1px;border-style:solid;}
/* SVG ANIMATION CARD */
.anim-card{background:#fff;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:12px;}
.anim-title{padding:12px 14px 0;font-size:13px;font-weight:800;color:var(--muted);}
.anim-card svg{display:block;width:100%;}
/* fact card */
.fact-card{border-radius:var(--radius-sm);padding:12px 14px;margin-bottom:8px;border-width:1px;border-style:solid;display:flex;gap:10px;align-items:flex-start;}
.fact-card .fc-icon{font-size:20px;flex-shrink:0;margin-top:1px;}
.fact-card .fc-text{font-size:13px;font-weight:600;line-height:1.5;}
/* QUIZ */
.quiz-tabs{display:flex;gap:6px;margin-bottom:16px;overflow-x:auto;padding-bottom:2px;}
.qtab{flex-shrink:0;padding:7px 14px;border:1px solid var(--border);border-radius:20px;font-size:12px;font-weight:800;cursor:pointer;background:#fff;font-family:'Nunito',sans-serif;color:var(--muted);}
.qtab.on{background:var(--green);border-color:var(--green);color:#fff;}
.quiz-intro{text-align:center;padding:20px 0;}
.qi-icon{font-size:52px;margin-bottom:12px;}
.qi-title{font-size:20px;font-weight:900;margin-bottom:8px;}
.qi-sub{font-size:13px;color:var(--muted);font-weight:600;line-height:1.6;margin-bottom:20px;}
.start-btn{width:100%;padding:16px;background:var(--green);border:none;border-radius:var(--radius-sm);font-size:15px;font-weight:800;color:#fff;cursor:pointer;font-family:'Nunito',sans-serif;}
.q-prog-wrap{height:6px;background:var(--bg);border-radius:6px;overflow:hidden;margin-bottom:12px;}
.q-prog{height:100%;background:var(--green);border-radius:6px;transition:width .4s;}
.q-meta{font-size:12px;font-weight:700;color:var(--muted);margin-bottom:10px;}
.q-txt{font-size:15px;font-weight:800;line-height:1.5;margin-bottom:14px;}
.q-opts{display:flex;flex-direction:column;gap:8px;margin-bottom:14px;}
.q-opt{padding:12px 14px;border:2px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-weight:700;color:var(--text);cursor:pointer;text-align:left;background:#fff;font-family:'Nunito',sans-serif;}
.q-opt:hover:not(:disabled){background:var(--green-bg);border-color:var(--green-border);}
.q-opt.correct{background:var(--green-bg);border-color:var(--green);color:var(--green-text);}
.q-opt.wrong{background:var(--red-bg);border-color:var(--red-border);color:var(--red-text);}
.q-fb{padding:11px 13px;border-radius:var(--radius-sm);font-size:13px;font-weight:700;line-height:1.5;margin-bottom:12px;display:none;border-width:1px;border-style:solid;}
.q-fb.on{display:block;}
.q-next{width:100%;padding:13px;background:var(--bg);border:2px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-weight:800;cursor:pointer;display:none;font-family:'Nunito',sans-serif;}
.q-next.on{display:block;}
/* MATCH quiz */
.match-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;}
.match-col{display:flex;flex-direction:column;gap:8px;}
.match-item{padding:10px 12px;border:2px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-weight:700;cursor:pointer;background:#fff;text-align:center;transition:all .15s;user-select:none;}
.match-item.selected{border-color:var(--blue);background:var(--blue-bg);color:var(--blue-text);}
.match-item.matched{border-color:var(--green);background:var(--green-bg);color:var(--green-text);cursor:default;}
.match-item.wrong-flash{border-color:var(--red);background:var(--red-bg);}
/* FILL quiz */
.fill-sentence{font-size:15px;font-weight:700;line-height:2;margin-bottom:14px;}
.fill-blank{display:inline-block;min-width:80px;border-bottom:2px solid var(--border);padding:0 6px;text-align:center;font-weight:800;cursor:pointer;}
.fill-blank.filled{border-color:var(--green);color:var(--green-text);}
.fill-blank.wrong{border-color:var(--red);color:var(--red-text);}
.fill-options{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;}
.fill-chip{padding:8px 14px;border:2px solid var(--border);border-radius:20px;font-size:13px;font-weight:700;cursor:pointer;background:#fff;transition:all .15s;}
.fill-chip:hover{border-color:var(--green-border);background:var(--green-bg);}
.fill-chip.used{opacity:.35;cursor:not-allowed;}
/* SORT quiz */
.sort-list{display:flex;flex-direction:column;gap:8px;margin-bottom:14px;}
.sort-item{padding:12px 14px;border:2px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-weight:700;background:#fff;display:flex;align-items:center;gap:10px;cursor:grab;user-select:none;}
.sort-item .sort-handle{font-size:16px;color:var(--muted);}
.sort-item.drag-over{border-color:var(--blue);background:var(--blue-bg);}
.sort-item.correct-pos{border-color:var(--green);background:var(--green-bg);}
.sort-item.wrong-pos{border-color:var(--red);background:var(--red-bg);}
/* RESULT */
.qr-wrap{text-align:center;padding:16px 0;}
.qr-ico{font-size:56px;margin-bottom:10px;}
.qr-title{font-size:22px;font-weight:900;margin-bottom:6px;}
.qr-score{font-size:48px;font-weight:900;color:var(--green);margin-bottom:6px;}
.qr-sub{font-size:13px;color:var(--muted);font-weight:600;margin-bottom:18px;line-height:1.6;}
.badges-row{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:20px;}
.bp{padding:6px 14px;border-radius:20px;font-size:12px;font-weight:800;border-width:1px;border-style:solid;}
.retry-btn{width:100%;padding:14px;background:#fff;border:2px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-weight:800;cursor:pointer;font-family:'Nunito',sans-serif;margin-bottom:10px;}
/* PROFILE */
.avatar{width:68px;height:68px;border-radius:50%;background:var(--green-bg);border:2px solid var(--green-border);display:flex;align-items:center;justify-content:center;font-size:32px;margin:0 auto 10px;}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px;}
.stat-c{background:#fff;border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;text-align:center;}
.stat-v{font-size:26px;font-weight:900;color:var(--green);}
.stat-l{font-size:11px;font-weight:700;color:var(--muted);margin-top:2px;}
.b-grid{display:flex;flex-wrap:wrap;gap:10px;margin-top:10px;}
.b-item{text-align:center;width:64px;}
.b-ico{font-size:26px;margin-bottom:3px;}
.b-nm{font-size:10px;font-weight:700;color:var(--muted);}
.b-item.locked .b-ico{filter:grayscale(1);opacity:.3;}
.b-item.locked .b-nm{color:#d1d5db;}
.toast{position:fixed;top:16px;left:50%;transform:translateX(-50%) translateY(-80px);background:#16a34a;color:#fff;padding:10px 20px;border-radius:20px;font-size:13px;font-weight:800;z-index:200;transition:transform .35s;white-space:nowrap;}
.toast.show{transform:translateX(-50%) translateY(0);}
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:150;align-items:flex-end;justify-content:center;}
.modal-bg.on{display:flex;}
.modal{background:#fff;border-radius:var(--radius) var(--radius) 0 0;padding:20px 16px 36px;width:100%;max-width:430px;max-height:90vh;overflow-y:auto;}
.modal-close{float:right;background:none;border:none;font-size:20px;cursor:pointer;color:var(--muted);}
</style>
</head>
<body>
<div class="toast" id="toast"></div>

<!-- SCAN -->
<div id="scanScr" class="scr on">
  <div class="hdr">
    <div class="hdr-name">Nutri<span>Zeka</span></div>
    <div class="xpb">⭐ <span id="xpShow">0</span> XP</div>
  </div>
  <div id="sm" class="pad">
    <label class="upload-area">
      <input type="file" id="gal" accept="image/*">
      <div style="font-size:38px;margin-bottom:10px">📷</div>
      <div style="font-size:15px;font-weight:800;margin-bottom:4px">Fotoğraf yükle</div>
      <div style="font-size:12px;color:var(--muted)">Barkod · Ambalaj · Besin etiketi</div>
    </label>
    <div class="or-div"><span>ya da</span></div>
    <label class="cam-area">
      <input type="file" id="cam" accept="image/*" capture="environment">
      📱 Kamerayla çek
    </label>
    <div class="tips-box">
      <div class="tips-lbl">Ne fotoğraflayabilirsin?</div>
      <div class="tip-row"><div class="t-dot"></div>Ürün ambalajı ön yüzü</div>
      <div class="tip-row"><div class="t-dot"></div>Besin değerleri etiketi</div>
      <div class="tip-row"><div class="t-dot"></div>Barkod (EAN / UPC)</div>
      <div class="tip-row"><div class="t-dot"></div>İçerik ve katkı maddesi listesi</div>
    </div>
  </div>
  <div id="sl" style="display:none" class="pad">
