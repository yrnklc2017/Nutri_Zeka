<script>
// ─── STATE ───────────────────────────────────────────────────────────
const AMS=["image/jpeg","image/png","image/gif","image/webp"];
const STS=["Görüntü işleniyor...","Barkod / etiket okunuyor...","Besin değerleri analiz ediliyor...","Katkı maddeleri kontrol ediliyor...","Sağlık puanı hesaplanıyor..."];
const ND=[
  {k:"kalori",l:"Kalori",i:"⚡",u:"kcal",f:v=>v<100?"g":v<300?"y":"r"},
  {k:"seker",l:"Şeker",i:"🍬",u:"g",f:v=>v<5?"g":v<12.5?"y":"r"},
  {k:"yag",l:"Yağ",i:"🧈",u:"g",f:v=>v<3?"g":v<17.5?"y":"r"},
  {k:"tuz",l:"Tuz",i:"🧂",u:"g",f:v=>v<0.3?"g":v<1.5?"y":"r"},
  {k:"protein",l:"Protein",i:"💪",u:"g",f:v=>v>=5?"g":v>=2?"y":"r"},
  {k:"lif",l:"Lif",i:"🌾",u:"g",f:v=>v>=3?"g":v>=1?"y":"r"},
];
const CC={
  g:{bg:"var(--green-bg)",bd:"var(--green-border)",tx:"var(--green-text)",st:"#16a34a"},
  y:{bg:"var(--yellow-bg)",bd:"var(--yellow-border)",tx:"var(--yellow-text)",st:"#d97706"},
  r:{bg:"var(--red-bg)",bd:"var(--red-border)",tx:"var(--red-text)",st:"#dc2626"},
};
let xp=0,scanCnt=0,ls=new Set(),qb=0,stmr=null,si=0;
let archive=[],currentResult=null,currentImg=null,cmpSelected=[];

// ─── PERSIST ─────────────────────────────────────────────────────────
function save(){try{localStorage.setItem("nz2_arc",JSON.stringify(archive));localStorage.setItem("nz2_xp",xp);localStorage.setItem("nz2_sc",scanCnt);localStorage.setItem("nz2_ls",JSON.stringify([...ls]));localStorage.setItem("nz2_qb",qb);}catch(e){}}
function load(){try{const a=localStorage.getItem("nz2_arc");if(a)archive=JSON.parse(a);xp=parseInt(localStorage.getItem("nz2_xp")||0);scanCnt=parseInt(localStorage.getItem("nz2_sc")||0);const l=localStorage.getItem("nz2_ls");if(l)ls=new Set(JSON.parse(l));qb=parseInt(localStorage.getItem("nz2_qb")||0);}catch(e){}}

// ─── BADGES ──────────────────────────────────────────────────────────
const BADGES=[
  {id:"scan1",ico:"🔍",nm:"İlk Tarama",c:()=>scanCnt>=1},
  {id:"scan5",ico:"📦",nm:"Kaşif",c:()=>scanCnt>=5},
  {id:"learn3",ico:"📚",nm:"Öğrenci",c:()=>ls.size>=3},
  {id:"learn5",ico:"🎓",nm:"Bilge",c:()=>ls.size>=5},
  {id:"learn8",ico:"🏫",nm:"Akademisyen",c:()=>ls.size>=8},
  {id:"quiz6",ico:"🏅",nm:"Test Geçti",c:()=>qb>=6},
  {id:"quiz9",ico:"🏆",nm:"Şampiyon",c:()=>qb>=9},
  {id:"xp100",ico:"⭐",nm:"100 XP",c:()=>xp>=100},
  {id:"arc5",ico:"🗂️",nm:"Koleksiyoner",c:()=>archive.length>=5},
];

function toast(msg){const t=document.getElementById("toast");t.textContent=msg;t.classList.add("show");setTimeout(()=>t.classList.remove("show"),2500);}
function addXP(n,msg){xp+=n;document.getElementById("xpShow").textContent=xp;toast(msg||`+${n} XP 🎉`);save();upProf();}

// ─── NAV ─────────────────────────────────────────────────────────────
const SCRIDS=["scanScr","arcScr","learnScr","quizScr","profScr"];
function sw(i){
  SCRIDS.forEach((s,j)=>{document.getElementById(s).classList.toggle("on",j===i);document.getElementById("n"+j).classList.toggle("on",j===i);});
  if(i===1)renderArchive();
  if(i===3){currentQuizType=0;renderQuizHome(0);}
  if(i===4)upProf();
}
function upProf(){
  document.getElementById("xpShow").textContent=xp;
  document.getElementById("stx").textContent=xp;
  document.getElementById("stsc").textContent=scanCnt;
  document.getElementById("stq").textContent=qb;
  document.getElementById("stl").textContent=ls.size;
  const lv=xp<50?"Çaylak":xp<150?"Acemi":xp<300?"Uzman":"Usta";
  document.getElementById("avl").textContent=`Seviye ${Math.floor(xp/50)+1} — ${lv}`;
  const bg=document.getElementById("bg");bg.innerHTML="";
  BADGES.forEach(b=>{const e=b.c();bg.innerHTML+=`<div class="b-item${e?"":" locked"}"><div class="b-ico">${b.ico}</div><div class="b-nm">${b.nm}</div></div>`;});
}

// ─── SCAN ─────────────────────────────────────────────────────────────
document.getElementById("gal").addEventListener("change",onF);
document.getElementById("cam").addEventListener("change",onF);
function onF(e){
  const f=e.target.files[0];if(!f)return;e.target.value="";
  const r=new FileReader();
  r.onload=ev=>{
    const du=ev.target.result;
    const m=du.match(/^data:([^;]+);base64,/);
    const mime=AMS.includes(m?m[1]:"x")?m[1]:"image/jpeg";
    currentImg=du;
    document.getElementById("pi").src=du;
    document.getElementById("sm").style.display="none";
    document.getElementById("sl").style.display="block";
    document.getElementById("se").style.display="none";
    document.getElementById("sr").style.display="none";
    si=0;document.getElementById("lst").textContent=STS[0];
    clearInterval(stmr);stmr=setInterval(()=>{si=(si+1)%STS.length;document.getElementById("lst").textContent=STS[si];},900);
    callAPI(du.split(",")[1],mime)
      .then(res=>{clearInterval(stmr);currentResult=res;rndr(res);document.getElementById("sl").style.display="none";document.getElementById("sr").style.display="block";scanCnt++;addXP(10,"Ürün tarandı! +10 XP 🔍");save();})
      .catch(err=>{clearInterval(stmr);document.getElementById("sl").style.display="none";document.getElementById("se").style.display="block";document.getElementById("em").textContent=err.message||"Bilinmeyen hata.";});
  };
  r.readAsDataURL(f);
}
function rScan(){currentResult=null;currentImg=null;document.getElementById("sm").style.display="block";["sl","se","sr"].forEach(id=>document.getElementById(id).style.display="none");}

async function callAPI(b64,mime){
  const prompt=`Bu fotoğraf bir gıda ürününe ait. BARKOD: numarayı oku ve ürünü tanı. AMBALAJ: tipik değerleri tahmin et. ETİKET: değerleri oku.
SADECE JSON döndür:{"urun_adi":"...","marka":"...","barkod":"...","besinler":{"kalori":{"deger":0,"birim":"kcal"},"seker":{"deger":0,"birim":"g"},"yag":{"deger":0,"birim":"g"},"doymus_yag":{"deger":0,"birim":"g"},"tuz":{"deger":0,"birim":"g"},"protein":{"deger":0,"birim":"g"},"karbonhidrat":{"deger":0,"birim":"g"},"lif":{"deger":0,"birim":"g"}},"puan":50,"derece":"İyi","uyarilar":[{"seviye":"red","mesaj":"sade Türkçe"}],"katki_maddeleri":[{"kod":"E471","ad":"...","guvenlik":"safe"}],"tavsiye":"2-3 cümle sade Türkçe.","tahmin":true}
PUAN(60 başlangıç):Şeker<5g+20,>22g-20|Yağ<3g+15,>20g-15|DYağ<1.5g+15,>5g-15|Tuz<0.3g+10,>1.5g-20|Lif>3g+10|Protein>5g+10
guvenlik:safe|caution|avoid — derece:Mükemmel|İyi|Orta|Zayıf|Kötü`;
  const resp=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,messages:[{role:"user",content:[{type:"image",source:{type:"base64",media_type:mime,data:b64}},{type:"text",text:prompt}]}]})});
  if(!resp.ok){const e=await resp.json().catch(()=>({}));throw new Error(e?.error?.message||`API hatası (${resp.status})`);}
  const data=await resp.json();
  const raw=data.content.map(c=>c.text||"").join("");
  try{return JSON.parse(raw.replace(/```json|```/g,"").trim());}catch{throw new Error("Yanıt ayrıştırılamadı.");}
}
function scoreColor(s){return s>=70?"g":s>=45?"y":"r";}
function rndr(r){
  const sc2=Math.max(0,Math.min(100,Math.round(r.puan||50)));
  const cl=scoreColor(sc2);const C=CC[cl];
  const arc=document.getElementById("sarc");arc.style.stroke=C.st;
  setTimeout(()=>{arc.style.strokeDashoffset=289-(289*sc2/100);},80);
  const sn=document.getElementById("sn");sn.textContent=sc2;sn.style.color=C.st;
  document.getElementById("ss").style.background=C.st;
  const sb=document.getElementById("sb");sb.textContent=r.derece||"Analiz";sb.style.cssText=`background:${C.bg};color:${C.tx};border:1px solid ${C.bd}`;
  document.getElementById("spn").textContent=r.urun_adi||"Bilinmeyen";
  document.getElementById("sps").textContent=(r.marka||"")+(r.barkod?" · 🔲"+r.barkod:"")+(r.tahmin?" · ⚡Tahmini":" · ✓Etiketten");
  const ng=document.getElementById("ng");ng.innerHTML="";
  const b=r.besinler||{};
  ND.forEach(nd=>{const raw=b[nd.k];if(raw==null)return;const val=typeof raw==="object"?raw.deger:raw;const unit=typeof raw==="object"?raw.birim:nd.u;const c=nd.f(val);const C2=CC[c];const badge=c==="g"?"✓ İyi":c==="y"?"~ Orta":"! Yüksek";ng.innerHTML+=`<div class="nut-c" style="border-bottom-color:${C2.st}"><div class="nt-i">${nd.i}</div><div class="nt-l">${nd.l}</div><div class="nt-v">${val}<small>${unit}</small></div><div class="nt-b" style="background:${C2.bg};color:${C2.tx};border:1px solid ${C2.bd}">${badge}</div></div>`;});
  const ww=document.getElementById("ww");ww.innerHTML="";
  const warns=r.uyarilar&&r.uyarilar.length?r.uyarilar:[{seviye:"green",mesaj:"Özel uyarı tespit edilmedi."}];
  warns.forEach(w=>{const key=["green","g"].includes(w.seviye)?"g":["yellow","y"].includes(w.seviye)?"y":"r";const C2=CC[key];const ic=key==="g"?"✅":key==="y"?"⚠️":"🚨";ww.innerHTML+=`<div class="warn-item" style="background:${C2.bg};border-color:${C2.bd};color:${C2.tx}">${ic} ${w.mesaj}</div>`;});
  const adds=r.katki_maddeleri||[];const adsec=document.getElementById("adsec");
  if(adds.length){adsec.style.display="block";const aw=document.getElementById("aw");aw.innerHTML="";adds.forEach(a=>{const C2=a.guvenlik==="safe"?CC.g:a.guvenlik==="caution"?CC.y:CC.r;const ai=a.guvenlik==="safe"?"✓":a.guvenlik==="caution"?"⚠":"✕";aw.innerHTML+=`<span class="add-chip" style="background:${C2.bg};border-color:${C2.bd};color:${C2.tx}">${ai} ${a.kod}${a.ad?" · "+a.ad:""}</span>`;});}
  else adsec.style.display="none";
  document.getElementById("at").textContent=r.tavsiye||"Dengeli beslenme için meyve ve sebzeyi ihmal etme!";
}

// ─── ARCHIVE ─────────────────────────────────────────────────────────
function saveToArchive(){
  if(!currentResult)return;
  archive.unshift({id:Date.now(),name:currentResult.urun_adi||"Bilinmeyen",marka:currentResult.marka||"",puan:Math.max(0,Math.min(100,Math.round(currentResult.puan||50))),img:currentImg,data:currentResult,date:new Date().toLocaleDateString("tr-TR")});
  if(archive.length>50)archive.pop();
  save();toast("Arşive eklendi! 📦");rScan();setTimeout(()=>sw(1),600);
}
function renderArchive(){
  const el=document.getElementById("arcList");
  if(!archive.length){el.innerHTML=`<div class="arc-empty"><div style="font-size:40px;margin-bottom:10px">📦</div><p style="font-size:14px;font-weight:600">Henüz arşiv yok.<br>Bir ürün tara ve Arşivle'ye bas!</p></div>`;return;}
  el.innerHTML="";
  archive.forEach(a=>{const cl=scoreColor(a.puan);const C=CC[cl];el.innerHTML+=`<div class="arc-item" onclick="showDetail(${a.id})">${a.img?`<img class="arc-thumb" src="${a.img}" alt="">`:`<div class="arc-thumb-ph">📦</div>`}<div class="arc-info"><div class="arc-name">${a.name}</div><div class="arc-meta">${a.marka?a.marka+" · ":""}${a.date}</div></div><div style="text-align:center;flex-shrink:0"><div class="arc-score-num" style="color:${C.st}">${a.puan}</div><div class="arc-score-lbl">puan</div></div><button class="arc-del" onclick="event.stopPropagation();delArc(${a.id})">🗑️</button></div>`;});
}
function delArc(id){archive=archive.filter(a=>a.id!==id);save();renderArchive();toast("Silindi.");}
function showDetail(id){
  const a=archive.find(x=>x.id===id);if(!a)return;
  const cl=scoreColor(a.puan);const C=CC[cl];const b=a.data.besinler||{};
