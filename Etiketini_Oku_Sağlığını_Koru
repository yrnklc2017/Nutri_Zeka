function showCompare(){
  if(archive.length<2){toast("Kıyas için en az 2 ürün arşivleyin!");return;}
  cmpSelected=[];
  document.getElementById("cmpContent").innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px"><div style="font-size:17px;font-weight:900">Ürün Kıyasla</div><button class="modal-close" onclick="closeCmp()">✕</button></div><div style="font-size:13px;color:var(--muted);font-weight:600;margin-bottom:10px">2 ürün seç:</div>${archive.map(a=>`<div class="cmp-sel" id="cs${a.id}" onclick="toggleCmp(${a.id})"><div><div class="cmp-sel-name">${a.name}</div><div class="cmp-sel-meta">${a.marka?a.marka+" · ":""}${a.date} · Puan: ${a.puan}</div></div><div class="cmp-check">✓</div></div>`).join("")}<button class="cmp-btn" id="doCmpBtn" onclick="doCompare()" disabled>Kıyasla →</button>`;
  document.getElementById("cmpModal").classList.add("on");
}
function toggleCmp(id){const idx=cmpSelected.indexOf(id);if(idx>-1){cmpSelected.splice(idx,1);document.getElementById("cs"+id).classList.remove("picked");}else if(cmpSelected.length<2){cmpSelected.push(id);document.getElementById("cs"+id).classList.add("picked");}document.getElementById("doCmpBtn").disabled=cmpSelected.length!==2;}
function doCompare(){
  const [a1,a2]=cmpSelected.map(id=>archive.find(a=>a.id===id));
  const C1=CC[scoreColor(a1.puan)],C2=CC[scoreColor(a2.puan)];
  let rows="";
  ND.forEach(nd=>{const r1=(a1.data.besinler||{})[nd.k],r2=(a2.data.besinler||{})[nd.k];if(!r1||!r2)return;const v1=typeof r1==="object"?r1.deger:r1,v2=typeof r2==="object"?r2.deger:r2,unit=typeof r1==="object"?r1.birim:nd.u;const good=nd.k==="protein"||nd.k==="lif";const w1=good?v1>v2:v1<v2,w2=good?v2>v1:v2<v1;rows+=`<div class="cmp-row"><div class="cmp-cell">${nd.l}</div><div class="cmp-cell ${v1===v2?"":w1?"cmp-winner":"cmp-loser"}">${v1}${unit}</div><div class="cmp-cell ${v1===v2?"":w2?"cmp-winner":"cmp-loser"}">${v2}${unit}</div></div>`;});
  const win=a1.puan>a2.puan?a1:a2.puan>a1.puan?a2:null;
  document.getElementById("cmpContent").innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px"><div style="font-size:17px;font-weight:900">Kıyas Sonucu</div><button class="modal-close" onclick="closeCmp()">✕</button></div><div class="cmp-table"><div class="cmp-hdr-row"><div class="cmp-hdr-cell">Besin</div><div class="cmp-hdr-cell" style="color:${C1.st}">${a1.name.substring(0,12)}</div><div class="cmp-hdr-cell" style="color:${C2.st}">${a2.name.substring(0,12)}</div></div><div class="cmp-row"><div class="cmp-cell">Puan</div><div class="cmp-cell" style="font-size:18px;font-weight:900;color:${C1.st}">${a1.puan}</div><div class="cmp-cell" style="font-size:18px;font-weight:900;color:${C2.st}">${a2.puan}</div></div>${rows}</div>${win?`<div class="adv-box"><div class="adv-lbl">🏆 Sonuç</div><div class="adv-txt"><strong>${win.name}</strong> daha sağlıklı! (${win.puan} puan)</div></div>`:`<div class="adv-box"><div class="adv-lbl">🤝 Sonuç</div><div class="adv-txt">İki ürün eşit puana sahip.</div></div>`}<button class="cmp-btn" style="background:#fff;border:2px solid var(--border);color:var(--text)" onclick="showCompare()">← Başka seç</button>`;
}
